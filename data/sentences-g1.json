    "char": "名",
    "reading": "な",
    "start": 3,
    "len": 1
   },
   "use": [
    "yomi",
    "kaki"
   ]
  },
  {
   "id": "g1-076-1",
   "text": "目をとじてじゅうまでかぞえる。",
