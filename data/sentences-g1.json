    "char": "文",
    "reading": "ブン",
    "start": 2,
    "len": 1
   },
   "use": [
    "yomi",
    "kaki"
   ]
  },
  {
   "id": "g1-072-2",
   "text": "みじかい文をこえにだしてよむ。",
   "target": {
    "char": "文",
    "reading": "ブン",
    "start": 4,
    "len": 1
   },
   "use": [
    "yomi",
    "kaki"
   ]
  },
  {
   "id": "g1-073-1",
   "text": "木のえだにことりがとまった。",
   "target": {
    "char": "木",
    "reading": "き",
    "start": 0,
    "len": 1
   },
   "use": [
    "yomi",
    "kaki"
   ]
  },
  {
   "id": "g1-073-2",
   "text": "木ようびにたいいくがある。",
   "target": {
    "char": "木",
    "reading": "モク",
    "start": 0,
    "len": 1
   },
   "use": [
    "yomi",
    "kaki"
   ]
  },
  {
   "id": "g1-074-1",
   "text": "としょかんで本をかりた。",
